# =========================
# Global ignores
# =========================
*.log
*.tmp
*.bak
.DS_Store

# Node modules
/frontend/node_modules/
frontend/build/

# React environment files (keep example only)
/frontend/.env
/frontend/.env.local
/frontend/.env.development
/frontend/.env.production

# =========================
# Spring Boot / Java ignores
# =========================
/backend/target/
/backend/*.iml
/backend/.idea/
/backend/.classpath
/backend/.project
/backend/.settings/
/backend/bin/
/backend/out/

# Spring Boot environment files
/backend/src/main/resources/application.properties
/backend/src/main/resources/application.yml

# Maven / Gradle files
/backend/.mvn/
backend/mvnw*


